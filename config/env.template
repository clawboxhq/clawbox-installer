# ClawBox Configuration
# This file configures your ClawBox installation

# NVIDIA API Configuration
# Get your API key from: https://build.nvidia.com/settings/api-keys

# Required: NVIDIA API Key for cloud inference
NVIDIA_API_KEY=

# Optional: Alternative API keys for different providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# OpenShell Gateway Configuration
OPENSHELL_GATEWAY=openshell-c
GATEWAY_PORT=8080

# OpenClaw Gateway Token (auto-generated if empty)
OPENCLAW_GATEWAY_TOKEN=

# Optional: Telegram Bot Token (for Telegram channel)
# TELEGRAM_BOT_TOKEN=

# Optional: Discord Bot Token (for Discord channel)
# DISCORD_BOT_TOKEN=

# Optional: Slack Tokens (for Slack channel)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Optional: Voice/TTS API keys
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=

# Optional: Search API keys
# BRAVE_API_KEY=
