# ClawBox Configuration
# This file configures your ClawBox installation

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Choose your provider: nvidia, openai, anthropic, openrouter
# Only one primary provider is used at a time

# Provider selection (default: nvidia)
PROVIDER=nvidia

# -----------------------------------------------------------------------------
# NVIDIA NIM API (default)
# -----------------------------------------------------------------------------
# Get your API key from: https://build.nvidia.com/settings/api-keys
# Models: nemotron-3-super-120b-a12b, nemotron-4-340b, llama-3.1-405b, etc.
NVIDIA_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo, etc.
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic API
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/settings/keys
# Models: claude-sonnet-4-20250514, claude-3-opus-20240229, etc.
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# OpenRouter API (multi-provider gateway)
# -----------------------------------------------------------------------------
# Get your API key from: https://openrouter.ai/keys
# Models: All major LLMs via single API
# OPENROUTER_API_KEY=

# =============================================================================
# OpenShell Gateway Configuration
# =============================================================================
OPENSHELL_GATEWAY=openshell-c
GATEWAY_PORT=8080

# OpenClaw Gateway Token (auto-generated if empty)
OPENCLAW_GATEWAY_TOKEN=

# =============================================================================
# Optional: Channel Integration Tokens
# =============================================================================
# Uncomment and configure to enable channel integrations

# Telegram Bot Token (for Telegram channel)
# TELEGRAM_BOT_TOKEN=

# Discord Bot Token (for Discord channel)
# DISCORD_BOT_TOKEN=

# Slack Tokens (for Slack channel)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# =============================================================================
# Optional: Voice/TTS API Keys
# =============================================================================
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=

# =============================================================================
# Optional: Search API Keys
# =============================================================================
# BRAVE_API_KEY=
